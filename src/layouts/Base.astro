---
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  structuredData?: object | object[];
  showFooter?: boolean;
}

const { title, description, ogImage, ogType, structuredData, showFooter = true } = Astro.props;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Harmony Market',
  url: Astro.site?.toString() || '',
  logo: (Astro.site?.toString() || '') + 'logo.svg',
  description: 'Curated music merch, rock history books, and signature fragrance — for people who live by the record.',
  sameAs: [],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Harmony Market',
  url: Astro.site?.toString() || '',
};

const schemas = Array.isArray(structuredData)
  ? [orgSchema, websiteSchema, ...structuredData]
  : structuredData
    ? [orgSchema, websiteSchema, structuredData]
    : [orgSchema, websiteSchema];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      structuredData={schemas}
    />
  </head>
  <body class="min-h-screen font-sans text-parchment">
    <header class="sticky top-0 z-40 border-b border-white/5 bg-ink/80 backdrop-blur-md">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2 group">
          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-amber text-ink font-display text-lg font-bold">H</span>
          <span class="font-display text-xl tracking-tight group-hover:text-amber transition">Harmony Market</span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm text-mist">
          <a href="/shop" class="hover:text-parchment transition">Shop</a>
          <a href="/collections/music-merch" class="hover:text-parchment transition">Music Merch</a>
          <a href="/collections/rock-books" class="hover:text-parchment transition">Books</a>
          <a href="/collections/fragrance" class="hover:text-parchment transition">Fragrance</a>
          <a href="/about" class="hover:text-parchment transition">About</a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/shop" class="hidden md:inline-block text-sm text-mist hover:text-parchment">Search</a>
          <a href="/cart" class="relative inline-flex items-center gap-2 rounded-full border border-white/10 px-4 py-1.5 text-sm hover:border-amber/60 hover:text-amber transition">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3h2l2.4 12.4a2 2 0 0 0 2 1.6h8.2a2 2 0 0 0 2-1.6L21 7H6"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/></svg>
            <span>Cart</span>
            <span id="cart-count" class="rounded-full bg-amber px-1.5 text-xs font-semibold text-ink min-w-[1.25rem] text-center">0</span>
          </a>
        </div>
      </nav>
    </header>

    <slot />

    {showFooter && (
      <footer class="mt-24 border-t border-white/5 bg-ink-2">
        <div class="mx-auto max-w-7xl px-6 py-16 grid gap-12 md:grid-cols-4">
          <div class="md:col-span-2">
            <div class="flex items-center gap-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-amber text-ink font-display text-lg font-bold">H</span>
              <span class="font-display text-xl">Harmony Market</span>
            </div>
            <p class="mt-4 max-w-md text-sm text-mist leading-relaxed">
              Curated music merch, rock-history books, and signature fragrance for people who live by the record. Every piece is handpicked — no filler.
            </p>
          </div>
          <div>
            <h4 class="font-display text-sm uppercase tracking-widest text-amber">Shop</h4>
            <ul class="mt-4 space-y-2 text-sm text-mist">
              <li><a href="/shop" class="hover:text-parchment">All products</a></li>
              <li><a href="/collections/music-merch" class="hover:text-parchment">Music merch</a></li>
              <li><a href="/collections/rock-books" class="hover:text-parchment">Books</a></li>
              <li><a href="/collections/fragrance" class="hover:text-parchment">Fragrance</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-display text-sm uppercase tracking-widest text-amber">Help</h4>
            <ul class="mt-4 space-y-2 text-sm text-mist">
              <li><a href="/about" class="hover:text-parchment">About</a></li>
              <li><a href="/contact" class="hover:text-parchment">Contact</a></li>
              <li><a href="/shipping" class="hover:text-parchment">Shipping & returns</a></li>
              <li><a href="/blog" class="hover:text-parchment">Journal</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/5">
          <div class="mx-auto max-w-7xl px-6 py-6 flex flex-col md:flex-row items-center justify-between text-xs text-mist">
            <p>© 2026 Harmony Market. All rights reserved.</p>
            <p class="mt-2 md:mt-0">Made for people who still flip the record over.</p>
          </div>
        </div>
      </footer>
    )}

    <script is:inline>
      (function () {
        function refresh() {
          try {
            const cart = JSON.parse(localStorage.getItem('hm_cart') || '[]');
            const count = cart.reduce((s, i) => s + (i.qty || 1), 0);
            const el = document.getElementById('cart-count');
            if (el) el.textContent = String(count);
          } catch (_) {}
        }
        refresh();
        window.addEventListener('storage', refresh);
        window.addEventListener('hm:cart', refresh);
      })();
    </script>
  </body>
</html>
